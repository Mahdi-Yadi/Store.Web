}

<partial name="_PageNavbar" />

<div class="customer_login mt-60">
	<div class="container">
		<div class="row">
			<div class="col-lg-12 col-md-12">
				<div class="account_form register">
					<h2>ثبت نام</h2>
					<form action="#">
						<p>
							<label>آدرس ایمیل <span>*</span></label>
